// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum BudgetType {
  FIXED
  HOURLY
  NEGOTIABLE
}

enum ServiceOfferStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}


model Address {
  id           String         @id @default(uuid()) @db.Uuid
  street       String         @db.VarChar(255)
  number       String?        @db.VarChar(20)
  complement   String?        @db.VarChar(100)
  neighborhood String?        @db.VarChar(100)
  city         String         @db.VarChar(100)
  state        String         @db.Char(2)       // UF
  zipCode      String         @db.VarChar(10)
  country      String         @default("BR") @db.Char(2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  users          User[]
  establishments Establishment[]

  @@index([city, state])
  @@index([zipCode])
  @@map("addresses")
}


model User {
  id         String     @id @default(uuid()) @db.Uuid
  email      String     @unique @db.VarChar(255)
  name       String     @db.VarChar(255)
  phone      String?    @db.VarChar(20)
  avatarUrl  String?    @db.Text
  status     UserStatus @default(ACTIVE)
  addressId  String?    @db.Uuid
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  address       Address?              @relation(fields: [addressId], references: [id], onDelete: SetNull)
  establishment Establishment?
  userRoles     UserRole[]
  subscriptions ServiceSubscription[]
  reviews       Review[]              @relation("ReviewAuthor")
  receivedReviews Review[]            @relation("ReviewTarget")

  @@index([email])
  @@index([status])
  @@index([addressId])
  @@map("users")
}


model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  userRoles         UserRole[]
  serviceOfferRoles ServiceOfferRole[]

  @@index([slug])
  @@map("roles")
}


model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}


model Establishment {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @unique @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  logoUrl     String?  @db.Text
  website     String?  @db.VarChar(255)
  addressId   String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  address       Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  serviceOffers ServiceOffer[]

  @@index([ownerId])
  @@index([slug])
  @@index([addressId])
  @@map("establishments")
}


model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  serviceOffers ServiceOffer[]

  @@index([slug])
  @@map("categories")
}


model ServiceOffer {
  id              String             @id @default(uuid()) @db.Uuid
  establishmentId String             @db.Uuid
  categoryId      String?            @db.Uuid
  title           String             @db.VarChar(255)
  description     String             @db.Text
  budget          Decimal?           @db.Decimal(12, 2)
  budgetType      BudgetType         @default(FIXED)
  status          ServiceOfferStatus @default(DRAFT)
  deadline        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  establishment   Establishment        @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requiredRoles   ServiceOfferRole[]
  subscriptions   ServiceSubscription[]
  reviews         Review[]

  @@index([establishmentId])
  @@index([categoryId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([budgetType, status])
  @@map("service_offers")
}


model ServiceOfferRole {
  id             String @id @default(uuid()) @db.Uuid
  serviceOfferId String @db.Uuid
  roleId         String @db.Uuid

  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([serviceOfferId, roleId])
  @@index([serviceOfferId])
  @@index([roleId])
  @@map("service_offer_roles")
}


model ServiceSubscription {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @db.Uuid
  serviceOfferId String             @db.Uuid
  status         SubscriptionStatus @default(PENDING)
  coverLetter    String?            @db.Text
  proposedBudget Decimal?           @db.Decimal(12, 2)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceOfferId])
  @@index([userId])
  @@index([serviceOfferId])
  @@index([status])
  @@index([userId, status])
  @@index([serviceOfferId, status])
  @@map("service_subscriptions")
}

model Review {
  id             String   @id @default(uuid()) @db.Uuid
  serviceOfferId String   @db.Uuid
  authorId       String   @db.Uuid
  targetId       String   @db.Uuid
  rating         Int      @db.SmallInt
  comment        String?  @db.Text
  createdAt      DateTime @default(now())

  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)
  author       User         @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target       User         @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([serviceOfferId, authorId, targetId])
  @@index([targetId])
  @@index([serviceOfferId])
  @@map("reviews")
}