// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  moduleFormat    = "cjs"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum BudgetType {
  FIXED
  HOURLY
  NEGOTIABLE
}

enum ServiceOfferStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}


model Address {
  id           Int            @id @default(autoincrement())
  slug         String         @unique @default(uuid()) @db.Uuid
  street       String         @db.VarChar(255)
  number       String?        @db.VarChar(20)
  complement   String?        @db.VarChar(100)
  neighborhood String?        @db.VarChar(100)
  city         String         @db.VarChar(100)
  state        String         @db.Char(2)
  zipCode      String         @db.VarChar(10)
  country      String         @default("BR") @db.Char(2)
  controls     Json?          @db.Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?      

  users          User[]
  establishments Establishment[]

  @@index([slug])
  @@index([city, state])
  @@index([zipCode])
  @@map("addresses")
}


model User {
  id         Int        @id @default(autoincrement())
  slug       String     @unique @default(uuid()) @db.Uuid
  email      String     @unique @db.VarChar(255)
  password   String     @db.VarChar(255)
  name       String     @db.VarChar(255)
  phone      String?    @db.VarChar(20)
  avatarUrl  String?    @db.Text
  status     UserStatus @default(ACTIVE)
  addressId  Int?
  controls   Json?      @db.Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  address       Address?              @relation(fields: [addressId], references: [id], onDelete: SetNull)
  establishment Establishment?
  userRoles     UserRole[]
  subscriptions ServiceSubscription[]
  reviews       Review[]              @relation("ReviewAuthor")
  receivedReviews Review[]            @relation("ReviewTarget")

  @@index([slug])
  @@index([email])
  @@index([status])
  @@index([addressId])
  @@map("users")
}


model Role {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  controls    Json?    @db.Json
  status      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  userRoles         UserRole[]
  serviceOfferRoles ServiceOfferRole[]
  @@index([slug])
  @@index([status])
  @@map("roles")
}


model UserRole {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @default(uuid()) @db.Uuid
  userId    Int
  roleId    Int
  controls  Json?    @db.Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([slug])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}


model Establishment {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @default(uuid()) @db.Uuid
  ownerId     Int      @unique
  name        String   @db.VarChar(255)
  description String?  @db.Text
  logoUrl     String?  @db.Text
  website     String?  @db.VarChar(255)
  addressId   Int?
  controls    Json?    @db.Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  address       Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  serviceOffers ServiceOffer[]

  @@index([slug])
  @@index([ownerId])
  @@index([addressId])
  @@map("establishments")
}


model Category {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  controls    Json?    @db.Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  serviceOffers ServiceOffer[]

  @@map("categories")
}


model ServiceOffer {
  id              Int                @id @default(autoincrement())
  slug            String             @unique @default(uuid()) @db.Uuid
  establishmentId Int
  categoryId      Int?
  title           String             @db.VarChar(255)
  description     String             @db.Text
  budget          Decimal?           @db.Decimal(12, 2)
  budgetType      BudgetType         @default(FIXED)
  status          ServiceOfferStatus @default(DRAFT)
  deadline        DateTime?
  controls        Json?              @db.Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  establishment   Establishment        @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requiredRoles   ServiceOfferRole[]
  subscriptions   ServiceSubscription[]
  reviews         Review[]

  @@index([slug])
  @@index([establishmentId])
  @@index([categoryId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([budgetType, status])
  @@map("service_offers")
}


model ServiceOfferRole {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @default(uuid()) @db.Uuid
  serviceOfferId Int
  roleId         Int
  controls       Json?    @db.Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([serviceOfferId, roleId])
  @@index([slug])
  @@index([serviceOfferId])
  @@index([roleId])
  @@map("service_offer_roles")
}


model ServiceSubscription {
  id             Int                @id @default(autoincrement())
  slug           String             @unique @default(uuid()) @db.Uuid
  userId         Int
  serviceOfferId Int
  status         SubscriptionStatus @default(PENDING)
  coverLetter    String?            @db.Text
  proposedBudget Decimal?           @db.Decimal(12, 2)
  controls       Json?              @db.Json
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceOfferId])
  @@index([slug])
  @@index([userId])
  @@index([serviceOfferId])
  @@index([status])
  @@index([userId, status])
  @@index([serviceOfferId, status])
  @@map("service_subscriptions")
}

model Review {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @default(uuid()) @db.Uuid
  serviceOfferId Int
  authorId       Int
  targetId       Int
  rating         Int      @db.SmallInt
  comment        String?  @db.Text
  controls       Json?    @db.Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  serviceOffer ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)
  author       User         @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target       User         @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([serviceOfferId, authorId, targetId])
  @@index([slug])
  @@index([targetId])
  @@index([serviceOfferId])
  @@map("reviews")
}